VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SITE_URL=https://letsfindpeople.com

# Keep Stripe secrets and SUPABASE_SERVICE_ROLE_KEY out of Vite/frontend env files.
# Set Edge Function secrets with `supabase secrets set` instead.
# Required Edge Function origin secrets:
#   supabase secrets set SITE_URL=https://letsfindpeople.com
# Optional comma-separated extra origins:
#   supabase secrets set SITE_URLS=http://localhost:5173,https://staging.example.com
